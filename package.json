{
  "name": "carrito-content-api",
  "version": "0.1.0",
  "private": true,
  "description": "API de contenido editorial, formularios de contacto y Libro de Reclamaciones para carrito-front",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/type-provider-typebox": "^5.1.0",
    "@sinclair/typebox": "^0.34.0",
    "env-schema": "^6.0.0",
    "fastify": "^5.10.0",
    "mongodb": "^6.10.0",
    "sanitize-html": "^2.17.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9.17.0",
    "mongodb-memory-server": "^10.1.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.10"
  }
}
