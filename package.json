{
  "name": "carrito-content-api",
  "version": "0.1.0",
  "private": true,
  "description": "API de contenido editorial, formularios de contacto y Libro de Reclamaciones para carrito-front",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:golden": "vitest run test/contract/export-contract.test.ts",
    "setup:contact": "tsx scripts/forms/setup-contact.ts",
    "setup:complaints": "tsx scripts/forms/setup-complaints.ts",
    "migrate:cache": "tsx scripts/migrate/import-cache.ts",
    "content:status": "tsx scripts/content/content-status.ts",
    "content:set": "tsx scripts/content/content-set.ts",
    "content:publish": "tsx scripts/content/content-publish.ts",
    "content:export": "tsx scripts/content/content-export.ts",
    "indexes:obsolete": "tsx scripts/db/report-obsolete-indexes.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@sinclair/typebox": "^0.34.0",
    "env-schema": "^6.0.0",
    "fastify": "^5.10.0",
    "mongodb": "^6.10.0",
    "nodemailer": "^9.0.3",
    "pngjs": "^7.0.0",
    "sanitize-html": "^2.17.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pngjs": "^6.0.5",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9.17.0",
    "mongodb-memory-server": "^10.1.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.10"
  }
}
