# carrito-content-api — plantilla de configuración validada al arranque (F7)
# Copiar a .env y completar. El archivo .env NUNCA se versiona.
# En producción el archivo vive fuera del repo (ver docs/runbook.md, F7)
# y su ruta se inyecta con CARRITO_ENV_FILE.

NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info

# MongoDB local (standalone; bindIp 127.0.0.1, nunca expuesto a Internet)
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_CONTENT=carrito_content
MONGO_DB_FORMS=carrito_forms

# Credenciales propias de carrito_forms (usuario Mongo distinto del de
# contenido — AGENTS.md, datos personales). Vacío = usa MONGO_URI (solo
# development/test). En producción es OBLIGATORIO y debe diferir de MONGO_URI.
MONGO_URI_FORMS=

# Claves del export servidor-a-servidor (X-Export-Key), separadas por coma
# (máx. 2 simultáneas; cada una ≥ 32 caracteres). Vacío = export deshabilitado.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXPORT_API_KEYS=

# Orígenes exactos del front autorizados por CORS, separados por coma.
# Solo http(s)://host[:puerto], sin wildcard, credenciales, ruta, query ni fragmento.
# Ejemplo: https://www.midominio.com,https://midominio.com. Vacío = CORS cerrado.
CORS_ORIGINS=

# Rate limiting de lectura pública (requests por IP por minuto)
RATE_LIMIT_READ_PER_MINUTE=120

# Rate limiting del formulario de contacto (contrato: 5 envíos / 10 min por IP)
RATE_LIMIT_CONTACT_MAX=5
RATE_LIMIT_CONTACT_WINDOW_MINUTES=10

# Formulario de contacto (F5 cerrado). true = registrado. false = kill-switch.
FEATURE_CONTACT_ENABLED=true

# ── Libro de Reclamaciones (F6) ──────────────────────────────────────────────
# GATE DE FASE (no kill-switch). Debe permanecer en false hasta cerrar el gate
# legal P1–P18 (formularios-backend-csharp.md §10; ADR-007). Su activación es
# una decisión EXPLÍCITA del usuario, nunca un despliegue. Con false, el
# endpoint responde 503 «no disponible» sin tocar la base.
FEATURE_COMPLAINTS_ENABLED=false

# Acuse EXPLÍCITO de que el gate legal P1–P18 está cerrado. Habilitar el Libro
# exige ADEMÁS poner esto en true: el flag de fase por sí solo NO basta (el
# arranque falla si se activa el Libro con este acuse en false). Nunca se pone
# en true sin autorización explícita del usuario.
COMPLAINTS_LEGAL_GATE_CLEARED=false

# Rate limit del Libro (mismo patrón que contacto).
RATE_LIMIT_COMPLAINTS_MAX=5
RATE_LIMIT_COMPLAINTS_WINDOW_MINUTES=10

# Los valores siguientes son OBLIGATORIOS solo si FEATURE_COMPLAINTS_ENABLED=true
# (el arranque falla si el flag está activo y faltan). NO son valores legales
# asumidos: se completan al cerrar el MR 1.

# Snapshot del proveedor persistido en cada reclamo (P8). Nunca sale del cache.
COMPLAINTS_PROVIDER_LEGAL_NAME=
COMPLAINTS_PROVIDER_RUC=
COMPLAINTS_PROVIDER_ADDRESS=

# Versión del texto de aceptación/confirmación (P1/P16) y plazo de respuesta en
# días (P1). El plazo legal vigente NO se asume: se configura al cerrar el MR 1.
COMPLAINTS_CONFIRMATION_TEXT_VERSION=
COMPLAINTS_RESPONSE_DAYS=0

# Política de firma (P18) y adjuntos (P14). Límites configurables; el total de
# firma + adjuntos debe ser como máximo 15 MiB para reservar al menos 1 MiB
# del límite BSON para la hoja y metadatos (un reclamo = un documento atómico).
COMPLAINTS_SIGNATURE_MAX_BYTES=262144
COMPLAINTS_ATTACHMENTS_MAX_FILES=5
COMPLAINTS_ATTACHMENTS_MAX_FILE_BYTES=4194304
COMPLAINTS_ATTACHMENTS_MAX_TOTAL_BYTES=12582912
COMPLAINTS_ATTACHMENTS_ALLOWED_TYPES=application/pdf,image/jpeg,image/png

# Correo de constancia (P2). Vacío = transporte no-op (no envía; el reclamo se
# persiste igual y el dispatch queda «pendiente»). Credenciales SOLO por env.
COMPLAINTS_SMTP_HOST=
COMPLAINTS_SMTP_PORT=587
COMPLAINTS_SMTP_SECURE=false
COMPLAINTS_SMTP_USER=
COMPLAINTS_SMTP_PASSWORD=
COMPLAINTS_SMTP_FROM=
